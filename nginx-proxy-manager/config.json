{
  "name": "Nginx Proxy Manager",
  "version": "2.14.0",
  "slug": "nginx-proxy-manager",
  "description": "Expose your services easily and securely with a beautiful GUI for Nginx. Tracks the latest upstream jc21/nginx-proxy-manager release.",
  "url": "https://github.com/NginxProxyManager/nginx-proxy-manager",
  "arch": ["amd64", "aarch64", "armv7"],
  "startup": "services",
  "boot": "auto",
  "ports": {
    "80/tcp": 80,
    "81/tcp": 81,
    "443/tcp": 443
  },
  "ports_description": {
    "80/tcp": "HTTP proxy traffic",
    "81/tcp": "Admin web UI",
    "443/tcp": "HTTPS proxy traffic"
  },
  "map": ["data:rw"],
  "options": {},
  "schema": {}
}
